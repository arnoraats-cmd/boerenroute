# Cloudflare Pages — schone URL's serveren vanaf de echte bestanden in /public.
# Status 200 = rewrite (URL blijft schoon, inhoud komt van het doelbestand).
# Eerste match wint, dus specifieke regels vóór wildcards.

/robots.txt         /public/robots.txt              200
# Schone /sitemap.xml direct (200-rewrite) serveren vanaf het echte bestand in /public.
/sitemap.xml        /public/sitemap.xml             200

/blog               /public/blog/index.html         200
/blog/              /public/blog/index.html         200
/blog/*             /public/blog/:splat.html        200

/regio/*            /public/regio/:splat.html       200

/gemeente           /public/gemeente/index.html     200
/gemeente/          /public/gemeente/index.html     200
/gemeente/*         /public/gemeente/:splat.html    200

/winkel/*           /public/winkel/:splat.html      200

/versautomaten      /public/versautomaten.html      200
/eierautomaten      /public/eierautomaten.html      200
/zelfpluktuinen     /public/zelfpluktuinen.html     200
/melktap            /public/melktap.html            200
/streekproducten    /public/streekproducten.html    200

# Categorie × provincie (bv. /eierautomaten/gelderland). Exacte regel hierboven wint
# voor /eierautomaten zelf; de wildcard vangt alleen de provincie-subpagina's.
/versautomaten/*    /public/versautomaten/:splat.html   200
/eierautomaten/*    /public/eierautomaten/:splat.html   200
/zelfpluktuinen/*   /public/zelfpluktuinen/:splat.html  200
/melktap/*          /public/melktap/:splat.html         200
/streekproducten/*  /public/streekproducten/:splat.html 200

/privacy            /public/privacy/index.html      200
/privacy/           /public/privacy/index.html      200

/aanmelden          /public/aanmelden/index.html    200
/aanmelden/         /public/aanmelden/index.html    200

/partners           /public/partners/index.html     200
/partners/          /public/partners/index.html     200
# Oude stichting-URL doorverwijzen naar de nieuwe partners-pagina
/stichting          /partners                       301
/stichting/         /partners                       301

/updates            /public/updates/index.html      200
/updates/           /public/updates/index.html      200
