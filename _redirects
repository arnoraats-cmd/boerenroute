# Cloudflare Pages — schone URL's serveren vanaf de echte bestanden in /public.
# Status 200 = rewrite (URL blijft schoon, inhoud komt van het doelbestand).
#
# BELANGRIJK — laat de .html WEG uit de targets. Cloudflare Pages stuurt elk
# *.html-bestand automatisch met een 308 door naar de extensieloze "schone"
# URL. Een target MÉT .html maakt van de stille 200-rewrite dus een zichtbare
# redirect naar /public/... → canonical-conflict en slechte indexering.
#   - Los bestand   →  /public/naam        (zonder .html, zonder slash)
#   - Map-landing   →  /public/naam/       (mét trailing slash; index.html)
#   - Splat-bestand →  /public/map/:splat  (zonder .html)
# Eerste match wint, dus specifieke regels vóór wildcards.

/robots.txt         /public/robots.txt              200
/sitemap.xml        /public/sitemap.xml             200

/blog               /public/blog/                   200
/blog/              /public/blog/                   200
/blog/*             /public/blog/:splat             200

/regio/*            /public/regio/:splat            200

/gemeente           /public/gemeente/               200
/gemeente/          /public/gemeente/               200
/gemeente/*         /public/gemeente/:splat         200

/winkel/*           /public/winkel/:splat           200

/versautomaten      /public/versautomaten           200
/eierautomaten      /public/eierautomaten           200
/zelfpluktuinen     /public/zelfpluktuinen          200
/melktap            /public/melktap                 200
/streekproducten    /public/streekproducten         200

# Categorie × provincie (bv. /eierautomaten/gelderland). Exacte regel hierboven
# wint voor /eierautomaten zelf; de wildcard vangt alleen de provincie-subpagina's.
/versautomaten/*    /public/versautomaten/:splat    200
/eierautomaten/*    /public/eierautomaten/:splat    200
/zelfpluktuinen/*   /public/zelfpluktuinen/:splat   200
/melktap/*          /public/melktap/:splat          200
/streekproducten/*  /public/streekproducten/:splat  200

/privacy            /public/privacy/                200
/privacy/           /public/privacy/                200

/aanmelden          /public/aanmelden/              200
/aanmelden/         /public/aanmelden/              200

/partners           /public/partners/               200
/partners/          /public/partners/               200
